test_path_trail =
  trail = encode (parse_path ".users[3].name")
  trail == "[\"users\",4,\"name\"]"

test_pretty_list = (pretty (must (decode "[1,2]")) 0) == "[\n  1,\n  2\n]"

test_pretty_map =
  rendered = pretty (must (decode "\{\"b\":2,\"a\":1}")) 0
  rendered == "\{\n  \"a\": 1,\n  \"b\": 2\n}"

test_pretty_scalar = (pretty 42 0) == "42"

test_walk =
  found = walk (must (decode "\{\"a\":[\{\"b\":7}]}")) (parse_path ".a[0].b")
  found == 7
