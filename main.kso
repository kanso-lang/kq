fn _apply text query
  _render_result (_walk (decode text) (_parse_path query))

fn _dispatch argv
  if ((length argv) == 0) _usage (_with_query argv)

fn _render_result (err reason)
  err reason

fn _render_result v
  print (_pretty v 0)

_usage = print "usage: kq <path> [file.json]   e.g. kq .users[3].name data.json"

fn _with_query argv
  source = if ((length argv) > 1) (read_file argv[2]) stdin
  source . _apply argv[1]

main = args . _dispatch
