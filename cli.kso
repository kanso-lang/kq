import "std/io"

fn apply text query
  render_result (walk (decode text) (parse_path query))

fn dispatch argv
  if ((length argv) == 0) usage (with_query argv)

fn render_result (err reason)
  err reason

fn render_result v
  print (pretty v 0)

usage = print "usage: kq <path> [file.json]   e.g. kq .users[3].name data.json"

fn with_query argv
  source = if ((length argv) > 1) (io/read_file argv[2]) io/stdin
  source . apply argv[1]
